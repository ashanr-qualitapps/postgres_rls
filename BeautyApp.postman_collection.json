{
  "info": {
    "name": "Beauty App API",
    "_postman_id": "beauty-app-api-v1",
    "description": "Multi-tenant beauty salon API.\n\n## Quick start\n1. Set the `base_url` collection variable (default: `http://localhost:8000`).\n2. Run **Login as Admin** (or any login request) – the test script automatically stores the JWT in the `token` collection variable.\n3. All other requests pick up the token from `{{token}}` via the collection-level Auth setting.\n\n## Seeded credentials (dev only)\n- Admin: `admin@beautyapp.com` / `password123`\n- Staff Downtown: `staff.downtown@beautyapp.com` / `password123`\n- Staff Uptown: `staff.uptown@beautyapp.com` / `password123`\n- Customer Alice: `alice@example.com` / `password123`\n- Customer Charlie: `charlie@example.com` / `password123`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://localhost:8000", "type": "string" },
    { "key": "token",          "value": "",                      "type": "string" },
    { "key": "branch_id",      "value": "11111111-0000-0000-0000-000000000001", "type": "string" },
    { "key": "service_id",     "value": "33333333-0000-0000-0000-000000000001", "type": "string" },
    { "key": "product_id",     "value": "55555555-0000-0000-0000-000000000001", "type": "string" },
    { "key": "appointment_id", "value": "", "type": "string" },
    { "key": "order_id",       "value": "", "type": "string" },
    { "key": "user_id",        "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
