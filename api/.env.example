# Beauty App – API environment variables
# Copy this file to .env (at the repo root, next to docker-compose.yml)
# and fill in the values before running `docker compose up`.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Must match the values used by the postgres service in docker-compose.yml
POSTGRES_DB=beauty_app
POSTGRES_USER=postgres          # superuser – used by the postgres container only
POSTGRES_PASSWORD=changeme      # superuser password

# Application service user (created by init/01_roles.sql)
# The API connects exclusively as this low-privilege login role.
APP_DB_USER=app_service_user
APP_DB_PASS=App_S3rvice_P@ss!

# ── pgAdmin ─────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@beautyapp.local
PGADMIN_PASSWORD=changeme

# ── JWT ─────────────────────────────────────────────────────────────────────
# REQUIRED in production: generate with  openssl rand -hex 32
JWT_SECRET=change-this-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── Port overrides (optional) ────────────────────────────────────────────────
POSTGRES_PORT=5432
PGADMIN_PORT=5050
API_PORT=8000
