meta {
  name: Create Branch [admin]
  type: http
  seq: 3
}

post {
  url: {{base_url}}/branches/
  body: json
  auth: inherit
}

body:json {
  {
    "name": "Midtown Branch",
    "address": "300 5th Ave",
    "phone": "+1-555-0303",
    "timezone": "America/New_York"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("branch_id", res.body.id);
    console.log("Branch id saved:", res.body.id);
  }
}
