meta {
  name: Login as Staff (Downtown)
  type: http
  seq: 2
}

post {
  url: {{base_url}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "staff.downtown@beautyapp.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("token", res.body.access_token);
    console.log("Staff (Downtown) token saved.");
  }
}
