meta {
  name: Login as Customer (Alice)
  type: http
  seq: 3
}

post {
  url: {{base_url}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "alice@example.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("token", res.body.access_token);
    console.log("Customer (Alice) token saved.");
  }
}
